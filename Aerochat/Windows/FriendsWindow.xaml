<Window x:Class="Aerochat.Windows.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aerochat.Windows"
        xmlns:controls="clr-namespace:Aerochat.Controls"
        xmlns:helpers="clr-namespace:Aerochat.Helpers"
        xmlns:converter="clr-namespace:Aerochat.Converter"
        xmlns:viewmodels="clr-namespace:Aerochat.ViewModels"
        xmlns:loc="clr-namespace:Aerochat.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:FriendsWindowViewModel}"
        Title="{loc:Loc FriendsWindowTitle}"
        Width="380" Height="520" MinWidth="320" MinHeight="400"
        Style="{StaticResource Window}">
    <Window.Resources>
        <helpers:ImageConverter x:Key="imageConverter" />
        <Style x:Key="FriendsSearchNineSliceStyle" TargetType="controls:ColorizedNineSlice">
            <Setter Property="Image" Value="/Aerochat;component/Resources/Home/SearchBarActive.png"/>
            <Setter Property="Darken" Value="0.3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, ElementName=FriendsSearchInput}" Value="">
                    <Setter Property="Image" Value="/Aerochat;component/Resources/Home/SearchBar.png"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, ElementName=FriendsSearchInput}" Value="True" />
                        <Condition Binding="{Binding Text, ElementName=FriendsSearchInput}" Value="" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Image" Value="/Aerochat;component/Resources/Home/SearchBarHover.png"/>
                    <Setter Property="Darken" Value="0" />
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=FriendsSearchInput}" Value="True">
                    <Setter Property="Image" Value="/Aerochat;component/Resources/Home/SearchBarActive.png"/>
                    <Setter Property="Darken" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FriendsOnlineDropdownIconStyle" TargetType="Image">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/Dropdown.png" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/DropdownHover.png" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsMouseOver}" Value="False" />
                        <Condition Binding="{Binding OnlineSectionCollapsed}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/DropdownExpanded.png" />
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsMouseOver}" Value="True" />
                        <Condition Binding="{Binding OnlineSectionCollapsed}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/DropdownExpandedHover.png" />
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FriendsOfflineDropdownIconStyle" TargetType="Image">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/Dropdown.png" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/DropdownHover.png" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsMouseOver}" Value="False" />
                        <Condition Binding="{Binding OfflineSectionCollapsed}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/DropdownExpanded.png" />
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsMouseOver}" Value="True" />
                        <Condition Binding="{Binding OfflineSectionCollapsed}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Source" Value="/Aerochat;component/Resources/Dropdown/DropdownExpandedHover.png" />
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="FriendContactRowTemplate" DataType="{x:Type viewmodels:FriendRowViewModel}">
            <Button Click="FriendRow_Click" HorizontalContentAlignment="Left" Style="{StaticResource TransparentStyle}">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Height" Value="{Binding ContactRowHeight}" />
                        </Style>
                    </Grid.Style>
                    <controls:NineSlice Slice="4,4">
                        <controls:NineSlice.Style>
                            <Style TargetType="controls:NineSlice">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Image" Value="/Aerochat;component/Resources/Home/TreeHover.png" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:NineSlice.Style>
                    </controls:NineSlice>
                    <Grid VerticalAlignment="Center">
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Margin" Value="16,0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContactRowUsesAvatarLayout}" Value="True">
                                            <Setter Property="Margin" Value="4,0" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Width="16" Height="16">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="/Aerochat;component/Resources/Frames/XSFrameOffline.png" />
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="Online">
                                                <Setter Property="Source" Value="/Aerochat;component/Resources/Frames/XSFrameActive.png" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="Idle">
                                                <Setter Property="Source" Value="/Aerochat;component/Resources/Frames/XSFrameIdle.png" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="DoNotDisturb">
                                                <Setter Property="Source" Value="/Aerochat;component/Resources/Frames/XSFrameDnd.png" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="Offline">
                                                <Setter Property="Source" Value="/Aerochat;component/Resources/Frames/XSFrameOffline.png" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="Invisible">
                                                <Setter Property="Source" Value="/Aerochat;component/Resources/Frames/XSFrameOffline.png" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="">
                                                <Setter Property="Source" Value="{Binding Image}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ContactRowUsesAvatarLayout}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <controls:ProfilePictureFrame
                                Grid.Column="0"
                                FrameSize="{Binding ContactAvatarFrameSize}"
                                EnableAnimation="False"
                                ProfilePicture="{Binding AvatarUrl, Converter={StaticResource imageConverter}}"
                                Margin="0,0,4,0">
                                <controls:ProfilePictureFrame.Style>
                                    <Style TargetType="controls:ProfilePictureFrame">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="UserStatus" Value="Online" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContactRowUsesAvatarLayout}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="Offline">
                                                <Setter Property="UserStatus" Value="Offline" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="Idle">
                                                <Setter Property="UserStatus" Value="Idle" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="DoNotDisturb">
                                                <Setter Property="UserStatus" Value="DoNotDisturb" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Presence.Status}" Value="Invisible">
                                                <Setter Property="UserStatus" Value="Invisible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:ProfilePictureFrame.Style>
                            </controls:ProfilePictureFrame>
                            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.Column="1">
                                <StackPanel.ToolTip>
                                    <ToolTip Content="{Binding Name}" />
                                </StackPanel.ToolTip>
                                <TextBlock Foreground="#333333" HorizontalAlignment="Left" Text="{Binding Name}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Presence.Status}" Value="">
                                                    <Setter Property="Margin" Value="2,0,0,0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <DockPanel>
                                    <Image Width="16" Height="16" Margin="0,0,3,0" VerticalAlignment="Center">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Presence.Type}" Value="Playing">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Source" Value="/Aerochat;component/Resources/Status/Playing.png" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Presence.Type}" Value="ListeningTo">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Source" Value="/Aerochat;component/Resources/Status/Listening.png" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Foreground="#888888" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Text" Value="{Binding Presence.Presence}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Presence.Presence}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>
    <controls:BaseTitlebar Color="{Binding Scene.Color}" BlackText="{Binding Scene.TextColor}">
        <Grid>
            <Grid.Background>
                <ImageBrush ImageSource="/Aerochat;component/Resources/bg-1.png" Stretch="UniformToFill" />
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Height="44" Margin="8,8,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="FriendsSearchInput" Background="Transparent" Height="28" VerticalContentAlignment="Center" VerticalAlignment="Center" Padding="12,0" Panel.ZIndex="5" Margin="7,0,23,0" BorderThickness="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="{x:Type TextBox}">
                                <Setter Property="Cursor" Value="Arrow" />
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="Cursor" Value="IBeam" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock TextTrimming="CharacterEllipsis" Foreground="#7F000000" Panel.ZIndex="6" IsHitTestVisible="False" Text="{loc:Loc FriendsWindowSearchPlaceholder}" VerticalAlignment="Center" Margin="20,0,36,0">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=FriendsSearchInput}" Value="False" />
                                            <Condition Binding="{Binding Text, ElementName=FriendsSearchInput}" Value="" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <controls:ColorizedNineSlice TintColor="{Binding Scene.Color}" Style="{StaticResource FriendsSearchNineSliceStyle}" Slice="16,16" />
                    <Image HorizontalAlignment="Right" Margin="0,0,15,0" Source="/Aerochat;component/Resources/Home/SearchIconGray.png" Width="16" Height="16" Panel.ZIndex="10" IsHitTestVisible="False"/>
                </Grid>
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0" PreviewMouseLeftButtonUp="AddFriendButton_Click">
                    <Grid.ToolTip>
                        <ToolTip Content="{loc:Loc FriendsWindowAddContactButton}" />
                    </Grid.ToolTip>
                    <controls:NineSliceButton Hover="/Aerochat;component/Resources/Message/ToolbarHover.png" Pressed="/Aerochat;component/Resources/Message/ToolbarActive.png" />
                    <StackPanel Margin="6" Orientation="Horizontal" IsHitTestVisible="False">
                        <Image Width="16" Height="16" Source="/Aerochat;component/Resources/Home/AddFriend.png" />
                        <Image Margin="4,0,0,0" Width="5" Source="/Aerochat;component/Resources/Home/Dropdown.png" />
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Panel.ZIndex="4" UseLayoutRounding="True" Margin="0,0,0,8">
                <controls:ColorizedNineSlice TintColor="{Binding Scene.Color}" Slice="1,1" Margin="0,0,0,6" Image="/Aerochat;component/Resources/Message/Separator.png" />
            </Grid>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="8,0,8,8" Background="Transparent">
                <StackPanel>
                    <!-- Online -->
                    <Grid Margin="0,0,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <controls:NineSlice Slice="4,4">
                                <controls:NineSlice.Style>
                                    <Style TargetType="controls:NineSlice">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=IsMouseOver}" Value="True">
                                                <Setter Property="Image" Value="/Aerochat;component/Resources/Home/TreeHover.png" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:NineSlice.Style>
                            </controls:NineSlice>
                            <Grid Height="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" PreviewMouseUp="FriendsOnlineSectionToggleCollapse" Style="{StaticResource FriendsOnlineDropdownIconStyle}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock FontSize="15" Foreground="#355a88" Text="{loc:Loc FriendsWindowOnline}" />
                                    <TextBlock FontSize="12" Foreground="#355a88" Opacity="0.52" Margin="1,0,0,0" VerticalAlignment="Center" Text="{Binding OnlineCategoryHeaderCountSuffix}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding OnlineFriends}" ItemTemplate="{StaticResource FriendContactRowTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OnlineSectionCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </Grid>
                    <!-- Offline -->
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <controls:NineSlice Slice="4,4">
                                <controls:NineSlice.Style>
                                    <Style TargetType="controls:NineSlice">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=IsMouseOver}" Value="True">
                                                <Setter Property="Image" Value="/Aerochat;component/Resources/Home/TreeHover.png" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:NineSlice.Style>
                            </controls:NineSlice>
                            <Grid Height="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" PreviewMouseUp="FriendsOfflineSectionToggleCollapse" Style="{StaticResource FriendsOfflineDropdownIconStyle}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock FontSize="15" Foreground="#355a88" Text="{loc:Loc FriendsWindowOffline}" />
                                    <TextBlock FontSize="12" Foreground="#355a88" Opacity="0.52" Margin="1,0,0,0" VerticalAlignment="Center" Text="{Binding OfflineCategoryHeaderCountSuffix}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding OfflineFriends}" ItemTemplate="{StaticResource FriendContactRowTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OfflineSectionCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </controls:BaseTitlebar>
</Window>
