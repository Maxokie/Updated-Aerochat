<Window x:Class="Aerochat.Windows.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Aerochat.Controls"
        xmlns:loc="clr-namespace:Aerochat.Localization"
        mc:Ignorable="d"
        MinHeight="163" Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="{loc:Loc UpdateAvailableWindowTitle}"
        Style="{StaticResource Window}">
    <controls:BaseTitlebar Color="#f1f6fb" BlackText="Black">
        <Grid>
            <Grid.Background>
                <ImageBrush ImageSource="/Aerochat;component/Resources/Dialog/Background.png" />
            </Grid.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="/Aerochat;component/Resources/Tray/Active.ico"
                           Width="32" Height="32" HorizontalAlignment="Left" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock TextWrapping="Wrap" Text="{loc:Loc UpdateAvailableTitle}"
                                   Foreground="#355a88" FontSize="19" />
                        <TextBlock x:Name="PART_NewVersion" TextWrapping="Wrap"
                                   Margin="0,6,0,0" Foreground="#333" FontWeight="SemiBold" />
                        <TextBlock x:Name="PART_CurrentVersion" TextWrapping="Wrap"
                                   Margin="0,2,0,0" Foreground="#555" />
                        <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#333"
                                   Text="{loc:Loc UpdateAvailablePrompt}" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <StackPanel Margin="15,11" FlowDirection="RightToLeft" Orientation="Horizontal" >
                        <Button x:Name="LaterButton" Click="LaterButton_Click"
                                Foreground="#333" Height="23" MinWidth="72"
                                Content="{loc:Loc UpdateAvailableLater}" />
                        <Button x:Name="DownloadButton" Click="DownloadButton_Click"
                                Foreground="#333" Height="23" MinWidth="72" Margin="0,0,6,0"
                                Content="{loc:Loc UpdateAvailableDownload}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </controls:BaseTitlebar>
</Window>
