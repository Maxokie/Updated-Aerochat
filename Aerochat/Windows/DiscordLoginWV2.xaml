<Window x:Class="Aerochat.Windows.DiscordLoginWV2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aerochat.Windows"
        mc:Ignorable="d"
        Title=".NET Passport Log-on" Height="200" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                       Text="Browser-based login is not supported on this version of Aerochat.&#x0a;&#x0a;Please use token login instead." />
            <Button Content="Close" Margin="0,16,0,0" Width="80" Click="OnClose" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
